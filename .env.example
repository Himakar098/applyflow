# ------------------------------------------------------------
# ApplyFlow environment example
# Copy to .env.local for local development.
# Only NEXT_PUBLIC_* variables are exposed to the browser.
# ------------------------------------------------------------

# Site metadata / public access
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@omnari.world
NEXT_PUBLIC_PUBLIC_BETA=false
NEXT_PUBLIC_BETA_LABEL=Access
NEXT_PUBLIC_BETA_ACCESS_MODE=open
NEXT_PUBLIC_BETA_BANNER_TEXT=

# Optional store links used by /extensions and /browser-extension
NEXT_PUBLIC_CHROME_EXTENSION_URL=
NEXT_PUBLIC_EDGE_EXTENSION_URL=
NEXT_PUBLIC_SAFARI_EXTENSION_URL=

# Firebase client configuration (required)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=0000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:0000000000:web:abcdef123456
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Optional local Firebase emulators
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Firebase Admin SDK (recommended: provide a single credential blob)
# Raw JSON or base64-encoded service account JSON
FIREBASE_ADMIN_CREDENTIAL=
# Legacy fallback name
FIREBASE_ADMIN_CREDENTIALS=

# Split Firebase Admin credentials (use only if not using FIREBASE_ADMIN_CREDENTIAL)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# AI provider settings
OPENAI_API_KEY=
JD_PARSE_USE_OPENAI=false
RECOMMENDATIONS_USE_OPENAI=false

# Daily AI / feature limits
DAILY_TAILORED_PACK_LIMIT=10
DAILY_BULLET_REWRITE_LIMIT=30
DAILY_RESUME_EXTRACT_LIMIT=10
DAILY_TOTAL_AI_LIMIT=50
DAILY_JD_PARSE_LIMIT=80
DAILY_JOB_SEARCH_LIMIT=60

# Job search and recommendation providers
JOB_SEARCH_PROVIDER=adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_API_KEY=
RECOMMENDATIONS_PROVIDER=mock

# Additional provider keys used by extended job-source / auto-apply paths
ZIPRECRUITER_API_KEY=
GLASSDOOR_API_KEY=

# Auto-apply / assisted-apply configuration
AUTO_APPLY_ENABLED=true
AUTO_APPLY_MAX_QUEUE_SIZE=1000
AUTO_APPLY_SCHEDULER_INTERVAL_MINUTES=10
AUTO_APPLY_DEFAULT_MAX_PER_DAY=5
AUTO_APPLY_DEFAULT_MIN_SCORE=70
AUTO_APPLY_DEFAULT_AUTO_SUBMIT=false

# Server-side access controls
BETA_ACCESS_MODE=open
BETA_REQUIRE_APPROVED_USERS=false
BETA_INVITE_CODES=

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
HEALTHCHECK_SECRET=

# E2E / local verification
E2E_BASE_URL=
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# API perf smoke
PERF_BASE_URL=
PERF_BEARER_TOKEN=
PERF_CONCURRENCY=5
PERF_REQUESTS=20
PERF_SEARCH_QUERY=Business Analyst
PERF_SEARCH_LOCATION=Perth

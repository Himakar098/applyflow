{
  "manifest_version": 3,
  "name": "ApplyFlow Autofill Assistant",
  "description": "Autofill job application forms and auto-apply to jobs with ApplyFlow.",
  "version": "0.2.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ApplyFlow Assistant"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}


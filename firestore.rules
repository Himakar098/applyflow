rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;

      // Auto-apply settings are edited client-side.
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      // Auto-apply analytics and manual tasks are currently read client-side.
      match /analytics/{documentId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /manual-tasks/{taskId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // All other user subcollections are written and read through trusted
      // server routes or server actions using the Admin SDK.
      match /{document=**} {
        allow read, write: if false;
      }
    }

    // These collections are written by trusted server code only.
    match /marketing/{document=**} {
      allow read, write: if false;
    }

    match /support/{document=**} {
      allow read, write: if false;
    }

    match /system/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
